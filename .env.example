# Copy this file to .env and fill in the values

# ── Docker Compose (docker-compose.yml reads these directly) ──────────────────

# Postgres password used by the Docker-managed database.
# docker-compose.yml builds DATABASE_URL from this automatically.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-strong-password

# Random secret used to sign sessions — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Comma-separated list of admin email addresses (must not be empty if you
# need admin access to export/import characters and view bug reports).
# Example: ADMIN_EMAILS=you@example.com,colleague@example.com
ADMIN_EMAILS=you@example.com

# ── Non-Docker / cloud deployments (Neon, Railway, Render, …) ────────────────

# Your Postgres connection string (not needed when using docker-compose.yml,
# which builds the URL from POSTGRES_PASSWORD above).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on (Railway/Render set this automatically)
PORT=5000

NODE_ENV=production
