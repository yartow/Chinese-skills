# Copy this file to .env and fill in the values

# Your Neon (or other Postgres) connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random secret used to sign sessions — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Port the server listens on (Railway/Render set this automatically)
PORT=5000

NODE_ENV=production
